/*-----------------------------------------------------------
ASSIGNMENT 5
Display all employees including KING.
-----------------------------------------------------------*/

SELECT E.ENAME "Employee",
E.EMPNO "Emp#",
M.ENAME "Manager",
M.EMPNO "Mgr#"
FROM EMP E
LEFT OUTER JOIN EMP M
ON E.MGR=M.EMPNO
ORDER BY E.EMPNO;

/*

KING will appear with NULL Manager.

*/


/*-----------------------------------------------------------
ASSIGNMENT 6
Display Structure of SALGRADE.
-----------------------------------------------------------*/

DESC SALGRADE;

/*

Name      Type
--------- -------
GRADE     NUMBER
LOSAL     NUMBER
HISAL     NUMBER

*/


/*-----------------------------------------------------------
Display Name,Job,Department,Salary and Grade.
-----------------------------------------------------------*/

SELECT E.ENAME,
E.JOB,
D.DNAME,
E.SAL,
S.GRADE
FROM EMP E
JOIN DEPT D
ON E.DEPTNO=D.DEPTNO
JOIN SALGRADE S
ON E.SAL BETWEEN S.LOSAL AND S.HISAL;

/*

ENAME JOB DNAME SAL GRADE
----- ---- ----- ---- -----
SMITH CLERK RESEARCH 800 1
ALLEN SALESMAN SALES 1600 3
...
KING PRESIDENT ACCOUNTING 5000 5

*/


