Department OPERATIONS appears with NULL employee.

*/


/*-----------------------------------------------------------
ASSIGNMENT 8
Employees hired before their managers.
-----------------------------------------------------------*/

SELECT E.ENAME,
E.HIREDATE,
M.ENAME MANAGER,
M.HIREDATE
FROM EMP E
LEFT JOIN EMP M
ON E.MGR=M.EMPNO
WHERE E.HIREDATE<M.HIREDATE;

/*

ENAME HIREDATE MANAGER HIREDATE
----- -------- ------- --------
Only employees hired before managers.

*/


/*-----------------------------------------------------------
ASSIGNMENT 9
Using USING clause.
-----------------------------------------------------------*/

SELECT EMPNO,
ENAME,
DNAME,
LOC
FROM EMP
JOIN DEPT
USING(DEPTNO)
WHERE JOB='CLERK';

/*

Displays all Clerks.

*/


/*-----------------------------------------------------------
ASSIGNMENT 10
Using ON clause.
-----------------------------------------------------------*/

SELECT ENAME,
SAL,
MGR,
DNAME
FROM EMP
JOIN DEPT
ON EMP.DEPTNO=DEPT.DEPTNO
WHERE SAL>2000;

/*

Displays employees earning >2000.

*/


/*-----------------------------------------------------------
ASSIGNMENT 11
