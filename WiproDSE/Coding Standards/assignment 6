*/


/*-----------------------------------------------------------
ASSIGNMENT 12
RIGHT OUTER JOIN
-----------------------------------------------------------*/

SELECT ENAME,
DNAME
FROM EMP
RIGHT OUTER JOIN DEPT
ON EMP.DEPTNO=DEPT.DEPTNO;

/*

Displays all departments including OPERATIONS.

*/


/*-----------------------------------------------------------
ASSIGNMENT 13
FULL OUTER JOIN
-----------------------------------------------------------*/

SELECT EMPNO,
DNAME,
LOC
FROM EMP
